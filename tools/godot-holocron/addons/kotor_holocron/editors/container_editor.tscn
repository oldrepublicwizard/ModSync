[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://addons/kotor_holocron/editors/container_editor.gd" id="1"]

[node name="ContainerEditor" type="VBoxContainer"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1")

[node name="Toolbar" type="HBoxContainer" parent="."]
layout_mode = 2

[node name="AddMemberButton" type="Button" parent="Toolbar"]
layout_mode = 2
text = "Add Member"

[node name="RemoveMemberButton" type="Button" parent="Toolbar"]
layout_mode = 2
text = "Remove"

[node name="CopyListingButton" type="Button" parent="Toolbar"]
layout_mode = 2
text = "Copy listing"

[node name="FilterEdit" type="LineEdit" parent="Toolbar"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
placeholder_text = "Filter resref or type…"

[node name="StatusLabel" type="Label" parent="Toolbar"]
unique_name_in_owner = true
layout_mode = 2
text = "Archive contents"

[node name="ResourceTree" type="Tree" parent="."]
unique_name_in_owner = true
layout_mode = 2
size_flags_vertical = 3
hide_root = true
column_titles_visible = true
select_mode = 0

[connection signal="pressed" from="Toolbar/AddMemberButton" to="." method="_on_add_member_pressed"]
[connection signal="pressed" from="Toolbar/RemoveMemberButton" to="." method="_on_remove_member_pressed"]
[connection signal="pressed" from="Toolbar/CopyListingButton" to="." method="_on_copy_listing_pressed"]
[connection signal="text_changed" from="Toolbar/FilterEdit" to="." method="_on_filter_changed"]
