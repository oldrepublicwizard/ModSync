<UserControl
    x:Class="ModSync.Dialogs.WizardPages.InstallStartPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="16,12" RowDefinitions="Auto,Auto,*,Auto">
        <TextBlock x:Name="HeaderText" Grid.Row="0" Margin="0,0,0,8" Text="🚀 Ready to Begin Installation" />
        <TextBlock Grid.Row="1" Margin="0,0,0,12" Text="Review your mod selection below. Click 'Next' to begin the installation process." TextWrapping="Wrap" />
        <Border Grid.Row="2" MinHeight="120" Padding="12" CornerRadius="8">
            <Grid RowDefinitions="Auto,*">
                <TextBlock x:Name="SelectedModsText" Grid.Row="0" Margin="0,0,0,8" />
                <ScrollViewer x:Name="ModListScrollViewer" Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="ModListPanel" Spacing="4" />
                </ScrollViewer>
            </Grid>
        </Border>
        <Border Grid.Row="3" Margin="0,12,0,0" Padding="12" CornerRadius="4">
            <StackPanel Spacing="6">
                <TextBlock Text="⚠️ Important" />
                <StackPanel Spacing="2">
                    <TextBlock Text="• The installation process cannot be fully reversed" />
                    <TextBlock Text="• Checkpoints will be created so you can roll back if needed" />
                    <TextBlock Text="• Do not close the application during installation" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
