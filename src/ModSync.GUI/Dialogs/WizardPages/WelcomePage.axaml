<UserControl
    x:Class="ModSync.Dialogs.WizardPages.WelcomePage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="WelcomePageRoot"
    d:DesignHeight="720"
    d:DesignWidth="1280"
    mc:Ignorable="d">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20,12" Spacing="12">
            <!--  Hero Section  -->
            <Border Padding="20,16" CornerRadius="12">
                <StackPanel HorizontalAlignment="Center" Spacing="8">
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="28"
                        FontWeight="Bold"
                        Text="Welcome to ModSync"
                        TextAlignment="Center" />
                    <TextBlock
                        MaxWidth="720"
                        HorizontalAlignment="Center"
                        Opacity="0.9"
                        Text="The complete multi-mod installation solution for Knights of the Old Republic"
                        TextAlignment="Center"
                        TextWrapping="Wrap" />
                    <StackPanel
                        Margin="0,4,0,0"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="16">
                        <TextBlock Text="✓ Automatic Dependencies" />
                        <TextBlock Text="✓ Cross-Platform" />
                        <TextBlock Text="✓ One-Click Install" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!--  The Problem & Solution Cards  -->
            <Grid ColumnDefinitions="*,12,*">
                <Border
                    Grid.Column="0"
                    Padding="14,12"
                    CornerRadius="10">
                    <StackPanel Spacing="6">
                        <TextBlock FontWeight="Bold" Text="&#x274C; The Problem" />
                        <TextBlock
                            Opacity="0.85"
                            Text="Installing multiple KOTOR mods is tedious and error-prone:"
                            TextWrapping="Wrap" />
                        <StackPanel Spacing="2">
                            <TextBlock Text="• Manual file copying and deletion" />
                            <TextBlock Text="• Complex install order requirements" />
                            <TextBlock Text="• One mistake = start over from scratch" />
                            <TextBlock Text="• Hours spent clicking through installers" />
                            <TextBlock Text="• Confusing compatibility instructions" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="2"
                    Padding="14,12"
                    CornerRadius="10">
                    <StackPanel Spacing="6">
                        <TextBlock FontWeight="Bold" Text="&#x2705; The Solution" />
                        <TextBlock
                            Opacity="0.85"
                            Text="ModSync automates everything for you:"
                            TextWrapping="Wrap" />
                        <StackPanel Spacing="2">
                            <TextBlock Text="• Select mods you want, click Install" />
                            <TextBlock Text="• Automatic dependency resolution" />
                            <TextBlock Text="• Smart install order management" />
                            <TextBlock Text="• No manual file operations needed" />
                            <TextBlock Text="• Built-in compatibility checking" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!--  Installation Process Steps  -->
            <Border Padding="14,12" CornerRadius="10">
                <StackPanel Spacing="8">
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontWeight="SemiBold"
                        Text="&#x1F4CB; Installation Process" />

                    <StackPanel Spacing="6">
                        <Border Padding="10,6" CornerRadius="6">
                            <Grid ColumnDefinitions="Auto,10,*">
                                <Border
                                    Grid.Column="0"
                                    Width="28"
                                    Height="28"
                                    CornerRadius="14"
                                    VerticalAlignment="Top">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Text="1" />
                                </Border>
                                <StackPanel Grid.Column="2" Spacing="2">
                                    <TextBlock FontWeight="SemiBold" Text="&#x1F4C1; Configure Directories" />
                                    <TextBlock
                                        Opacity="0.85"
                                        Text="Point to your KOTOR installation and mod workspace folder"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Padding="10,6" CornerRadius="6">
                            <Grid ColumnDefinitions="Auto,10,*">
                                <Border
                                    Grid.Column="0"
                                    Width="28"
                                    Height="28"
                                    CornerRadius="14"
                                    VerticalAlignment="Top">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Text="2" />
                                </Border>
                                <StackPanel Grid.Column="2" Spacing="2">
                                    <TextBlock FontWeight="SemiBold" Text="&#x1F4C4; Load Instruction File" />
                                    <TextBlock
                                        Opacity="0.85"
                                        Text="Choose a curated mod build from popular configurations"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Padding="10,6" CornerRadius="6">
                            <Grid ColumnDefinitions="Auto,10,*">
                                <Border
                                    Grid.Column="0"
                                    Width="28"
                                    Height="28"
                                    CornerRadius="14"
                                    VerticalAlignment="Top">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Text="3" />
                                </Border>
                                <StackPanel Grid.Column="2" Spacing="2">
                                    <TextBlock FontWeight="SemiBold" Text="&#x1F3AF; Select Your Mods" />
                                    <TextBlock
                                        Opacity="0.85"
                                        Text="Browse by category or tier — dependencies auto-select"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Padding="10,6" CornerRadius="6">
                            <Grid ColumnDefinitions="Auto,10,*">
                                <Border
                                    Grid.Column="0"
                                    Width="28"
                                    Height="28"
                                    CornerRadius="14"
                                    VerticalAlignment="Top">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Text="4" />
                                </Border>
                                <StackPanel Grid.Column="2" Spacing="2">
                                    <TextBlock FontWeight="SemiBold" Text="&#x2B07;&#xFE0F; Automatic Downloads" />
                                    <TextBlock
                                        Opacity="0.85"
                                        Text="Missing mods download in the background while you continue"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Padding="10,6" CornerRadius="6">
                            <Grid ColumnDefinitions="Auto,10,*">
                                <Border
                                    Grid.Column="0"
                                    Width="28"
                                    Height="28"
                                    CornerRadius="14"
                                    VerticalAlignment="Top">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Text="5" />
                                </Border>
                                <StackPanel Grid.Column="2" Spacing="2">
                                    <TextBlock FontWeight="SemiBold" Text="&#x2705; Validation &amp; Install" />
                                    <TextBlock
                                        Opacity="0.85"
                                        Text="Verify everything is ready, then install automatically"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!--  Key Features (compact 2x2)  -->
            <Border Padding="14,12" CornerRadius="10">
                <StackPanel Spacing="8">
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontWeight="SemiBold"
                        Text="&#x1F31F; Key Features" />

                    <Grid ColumnDefinitions="*,10,*" RowDefinitions="Auto,6,Auto">
                        <Border Grid.Row="0" Grid.Column="0" Padding="10,8" CornerRadius="8">
                            <StackPanel Spacing="4">
                                <TextBlock FontWeight="SemiBold" Text="Smart Dependencies" TextAlignment="Center" />
                                <TextBlock
                                    Opacity="0.8"
                                    Text="Resolves and installs required mods in the correct order"
                                    TextAlignment="Center"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="0" Grid.Column="2" Padding="10,8" CornerRadius="8">
                            <StackPanel Spacing="4">
                                <TextBlock FontWeight="SemiBold" Text="Pre-Install Validation" TextAlignment="Center" />
                                <TextBlock
                                    Opacity="0.8"
                                    Text="Catches compatibility issues before installation starts"
                                    TextAlignment="Center"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2" Grid.Column="0" Padding="10,8" CornerRadius="8">
                            <StackPanel Spacing="4">
                                <TextBlock FontWeight="SemiBold" Text="Checkpoint System" TextAlignment="Center" />
                                <TextBlock
                                    Opacity="0.8"
                                    Text="Roll back to previous states if something goes wrong"
                                    TextAlignment="Center"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2" Grid.Column="2" Padding="10,8" CornerRadius="8">
                            <StackPanel Spacing="4">
                                <TextBlock FontWeight="SemiBold" Text="Cross-Platform" TextAlignment="Center" />
                                <TextBlock
                                    Opacity="0.8"
                                    Text="Works on Windows, Linux, and macOS without Wine"
                                    TextAlignment="Center"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <!--  Important Notice  -->
            <Border Padding="14,12" CornerRadius="10">
                <Grid ColumnDefinitions="Auto,10,*">
                    <TextBlock
                        Grid.Column="0"
                        VerticalAlignment="Top"
                        Text="&#x26A0;&#xFE0F;" />
                    <StackPanel Grid.Column="2" Spacing="4">
                        <TextBlock FontWeight="Bold" Text="Important: Fresh Installation Required" />
                        <TextBlock
                            Opacity="0.9"
                            Text="For best results, start with a clean KOTOR install. If you previously installed mods manually, uninstall and reinstall the game before proceeding."
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>

            <!--  Ready to Begin  -->
            <Border Padding="16,12" CornerRadius="10">
                <StackPanel HorizontalAlignment="Center" Spacing="4">
                    <TextBlock
                        FontWeight="Bold"
                        Text="Ready to transform your KOTOR experience?"
                        TextAlignment="Center"
                        TextWrapping="Wrap" />
                    <TextBlock
                        Opacity="0.8"
                        Text="Click Next to begin the installation wizard"
                        TextAlignment="Center" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
