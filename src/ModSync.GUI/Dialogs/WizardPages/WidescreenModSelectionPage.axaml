<UserControl
    x:Class="ModSync.Dialogs.WizardPages.WidescreenModSelectionPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="16,12" RowDefinitions="Auto,Auto,*">
        <TextBlock Grid.Row="0" Margin="0,0,0,8" Text="Select widescreen mods (optional):" />
        <TextBlock x:Name="SelectionSummaryText" Grid.Row="1" Margin="0,0,0,12" TextWrapping="Wrap" />
        <Border Grid.Row="2" MinHeight="100" Padding="8" CornerRadius="8">
            <ScrollViewer x:Name="ModListScrollViewer" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="ModListPanel" Spacing="8" />
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
