<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwExceptions="false"
      internalLogLevel="Off">

  <targets>
    <!-- File target with date-based naming -->
    <target name="file"
            xsi:type="File"
            fileName="${basedir}/Logs/kotormodsync_${shortdate}.log"
            encoding="utf-8"
            layout="${longdate} ${message}"
            archiveEvery="Day"
            archiveNumbering="Date"
            maxArchiveFiles="30" />

    <!-- Console target with color coding -->
    <target name="console"
            xsi:type="ColoredConsole"
            encoding="utf-8"
            layout="${time:format=HH\:mm\:ss} ${message}">
      <highlight-row condition="level == LogLevel.Debug" foregroundColor="DarkGray" />
      <highlight-row condition="level == LogLevel.Warn" foregroundColor="Yellow" />
      <highlight-row condition="level == LogLevel.Error" foregroundColor="Red" />
      <highlight-row condition="level == LogLevel.Fatal" foregroundColor="Red" />
    </target>

    <!-- Memory target for log history (recent logs for error context) -->
    <target name="memory"
            xsi:type="Memory"
            layout="${time:format=HH\:mm\:ss} ${message}"
            maxLogsCount="200" />
  </targets>

  <rules>
    <!-- Log Info and above to file + memory always -->
    <logger name="*" minlevel="Info" writeTo="file,memory" />

    <!-- Mirror Info+ to console unless machine-readable CLI mode suppresses it -->
    <logger name="*" minlevel="Info" writeTo="console">
      <filters>
        <when condition="'${gdc:item=SuppressConsoleLogging}' == 'true'" action="Ignore" />
      </filters>
    </logger>

    <!-- Log Debug (verbose) to file + memory -->
    <logger name="*" level="Debug" writeTo="file,memory" final="true">
      <filters>
        <when condition="'${gdc:item=DebugLogging}' != 'true'" action="Ignore" />
      </filters>
    </logger>

    <!-- Mirror Debug to console when verbose logging is enabled -->
    <logger name="*" level="Debug" writeTo="console" final="true">
      <filters>
        <when condition="'${gdc:item=DebugLogging}' != 'true'" action="Ignore" />
        <when condition="'${gdc:item=SuppressConsoleLogging}' == 'true'" action="Ignore" />
      </filters>
    </logger>
  </rules>
</nlog>

